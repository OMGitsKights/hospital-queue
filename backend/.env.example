# CareFlo Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Flask settings
FLASK_ENV=development          # set to "production" on Render/Railway
FLASK_DEBUG=true               # set to "false" in production

# Server
PORT=5001

# Security — CHANGE THIS in production!
SECRET_KEY=careflo-dev-secret-change-in-prod

# Data directory (JSON stores). Defaults to ./data relative to app.py
# DATA_DIR=/path/to/data

# CORS — comma-separated origins, or "*" for open access
CORS_ORIGINS=http://localhost:3000
